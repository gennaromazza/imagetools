{
  "name": "photo-tools",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev:auto-layout",
    "dev:auto-layout": "npm --workspace @photo-tools/auto-layout-app run dev",
    "dev:all:auto-layout": "npm run dev:auto-layout",
    "dev:image-party-frame": "npm --workspace @photo-tools/image-party-frame-app run dev",
    "dev:all:image-party-frame": "npm --workspace @photo-tools/image-party-frame-app run dev:all",
    "dev:photo-selector": "npm --workspace @photo-tools/photo-selector-app run dev",
    "dev:archivio-flow": "npm --workspace @photo-tools/archivio-flow run dev",
    "dev:all:archivio-flow": "npm --workspace @photo-tools/archivio-flow run dev:all",
    "dev:image-id-print": "npm --workspace @photo-tools/image-id-print run dev",
    "dev:filex-desktop:photo-selector": "npm --workspace @photo-tools/filex-desktop run dev:photo-selector",
    "dev:filex-desktop:suite": "npm --workspace @photo-tools/filex-desktop run start:suite",
    "build:filex-desktop:photo-selector": "npm --workspace @photo-tools/filex-desktop run build:photo-selector",
    "build:filex-desktop:suite": "npm --workspace @photo-tools/filex-desktop run build:suite",
    "dist:filex-desktop:photo-selector:win": "npm --workspace @photo-tools/filex-desktop run dist:photo-selector:win",
    "dist:filex-desktop:suite:win": "npm --workspace @photo-tools/filex-desktop run dist:suite:win",
    "dist:filex-desktop:all-tools:win": "npm --workspace @photo-tools/filex-desktop run dist:all-tools:win",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
